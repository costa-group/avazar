(set-info :smt-lib-version 2.6)
(set-logic QF_FFA 21888242871839275222246405745257275088548364400416034343698204186575808495617)
(declare-fun a_0 () Int)
(declare-fun a_1 () Int)
(declare-fun b_0 () Int)
