  (not (= cout_0 cout_0p))
  (not (= cout_1 cout_1p))  
  (not (= c_chunks_0 c_chunks_0p)) 
  (not (= c_chunks_1 c_chunks_1p))
  (not (= c_chunks_2 c_chunks_2p))
